{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "he4rt/sycorax",
    "type": "project",
    "description": "",
    "keywords": [
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "alizharb/filament-activity-log": "^1.3.1",
        "basementdevs/filament-better-mails": "^5.1.5",
        "filament/filament": "^5.4.1",
        "filament/spatie-laravel-media-library-plugin": "^5.4.1",
        "guava/filament-knowledge-base": "^3.0.1",
        "he4rt/identity": "^1.0.0",
        "he4rt/panel-admin": "^1.0.0",
        "he4rt/widget-player": ">=1",
        "internachi/modular": "^3.0.2",
        "joaopaulolndev/filament-edit-profile": "^3.0.2",
        "laravel/framework": "^12.55.1",
        "laravel/tinker": "^2.11.1",
        "monicahq/laravel-cloudflare": "^4.0.0",
        "owenvoke/blade-fontawesome": "^3.2.2",
        "saloonphp/saloon": "^3.15",
        "spatie/laravel-activitylog": "^4.12.3",
        "spatie/laravel-backup": "^9.4.1",
        "spatie/laravel-permission": "^6.25.0",
        "stechstudio/filament-impersonate": "^5.1",
        "tpetry/laravel-postgresql-enhanced": "^3.6.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2.0",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.1.3",
        "larastan/larastan": "^3.9.3",
        "laravel/boost": "^2.3.4",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.29.0",
        "laravel/telescope": "^5.18.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4.3",
        "pestphp/pest-plugin-faker": "^4.0.0",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-livewire": "^4.1.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "2.1.34",
        "rector/rector": "^2.3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "bun install",
            "composer run-script post-root-package-install",
            "composer run-script post-create-project-cmd",
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --ansi",
            "@php artisan modules:sync --no-phpunit --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bun run concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite"
        ],
        "pint": "vendor/bin/pint --parallel",
        "test:pint": "vendor/bin/pint --test --parallel",
        "rector": "vendor/bin/rector",
        "test:rector": "vendor/bin/rector --dry-run",
        "phpstan": "vendor/bin/phpstan analyse --ansi",
        "test:phpstan": "vendor/bin/phpstan analyse --ansi",
        "test:unit": "vendor/bin/pest --parallel --compact --group=unit",
        "test:feature": "vendor/bin/pest --parallel --compact --group=feature",
        "test:browser": "vendor/bin/pest --parallel --compact --group=browser",
        "test:cov": "vendor/bin/pest --parallel --compact --coverage",
        "check": [
            "@test:rector",
            "@test:pint",
            "@test:phpstan"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "vendor/bin/pest --parallel --compact"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan modules:sync --no-phpunit --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-debugbar",
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "bump-after-update": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "report"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "app-modules/*",
            "options": {
                "symlink": true
            }
        }
    ]
}
